<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>万璇の谷子店</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(145deg, #eef2ff 0%, #e0e9ff 100%);
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', 'Poppins', sans-serif;
            color: #0a2b3e;
            scroll-behavior: smooth;
        }

        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f5f9;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

        .app {
            max-width: 1600px;
            margin: 24px auto;
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(20px);
            border-radius: 56px;
            box-shadow: 0 30px 50px -20px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(255,255,255,0.6);
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .student-badge {
            background: linear-gradient(105deg, #0c4a6e, #1e6f9f);
            color: #f0f9ff;
            text-align: center;
            padding: 12px 24px;
            font-size: 0.85rem;
            font-weight: 500;
            letter-spacing: 0.3px;
            backdrop-filter: blur(4px);
            border-bottom: 1px solid rgba(255,255,255,0.2);
        }

        .header {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(24px);
            border-bottom: 1px solid rgba(125, 211, 252, 0.3);
            padding: 20px 48px 16px;
        }

        .top-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
            margin-bottom: 20px;
        }

        .logo h1 {
            font-size: 2rem;
            font-weight: 700;
            background: linear-gradient(135deg, #0ea5e9, #38bdf8, #0284c7);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            letter-spacing: -0.3px;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(56, 189, 248, 0.15);
            backdrop-filter: blur(8px);
            padding: 6px 24px;
            border-radius: 60px;
            border: 0.5px solid rgba(255,255,255,0.6);
        }
        .user-name {
            font-weight: 700;
            color: #0c4a6e;
        }
        .logout-btn {
            background: none;
            border: none;
            color: #ef4444;
            cursor: pointer;
            font-weight: 500;
            font-size: 0.8rem;
            transition: 0.2s;
        }
        .logout-btn:hover {
            opacity: 0.7;
        }

        .nav-search-row {
            display: flex;
            align-items: center;
            gap: 24px;
            flex-wrap: wrap;
        }
        .nav-links {
            display: flex;
            gap: 12px;
            background: rgba(255,255,255,0.45);
            padding: 5px 12px;
            border-radius: 80px;
            backdrop-filter: blur(8px);
        }
        .nav-btn {
            background: none;
            border: none;
            padding: 8px 24px;
            font-size: 0.95rem;
            font-weight: 600;
            color: #0c4a6e;
            border-radius: 60px;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .nav-btn i {
            font-size: 1rem;
        }
        .nav-btn:hover, .nav-btn.active {
            background: #7dd3fc;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 16px -6px rgba(56, 189, 248, 0.4);
        }
        .search-wrapper {
            flex: 2;
            min-width: 240px;
        }
        .search-box {
            display: flex;
            gap: 12px;
            width: 100%;
        }
        .search-box input {
            flex: 1;
            padding: 12px 24px;
            border: 1px solid rgba(125, 211, 252, 0.5);
            border-radius: 80px;
            font-size: 0.95rem;
            background: rgba(255,255,255,0.8);
            backdrop-filter: blur(4px);
            transition: all 0.2s;
            font-weight: 500;
        }
        .search-box input:focus {
            outline: none;
            border-color: #38bdf8;
            box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.2);
            background: white;
        }
        .search-box button {
            background: linear-gradient(105deg, #0ea5e9, #38bdf8);
            border: none;
            padding: 0 32px;
            border-radius: 80px;
            color: white;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            transition: 0.2s;
            box-shadow: 0 6px 14px rgba(14, 165, 233, 0.3);
        }
        .search-box button:hover {
            transform: scale(1.02);
            box-shadow: 0 8px 20px rgba(14, 165, 233, 0.4);
        }

        .main-content {
            padding: 40px 48px 48px;
        }

        .page {
            display: none;
            animation: fadeSlideUp 0.5s cubic-bezier(0.2, 0.9, 0.4, 1.1);
        }
        .active-page { display: block; }
        @keyframes fadeSlideUp {
            from { opacity: 0; transform: translateY(18px);}
            to { opacity: 1; transform: translateY(0);}
        }

        /* 轮播图 - 淡入淡出样式 */
        .carousel {
            position: relative;
            width: 100%;
            height: 500px;
            overflow: hidden;
            border-radius: 40px;
            margin-bottom: 56px;
            box-shadow: 0 25px 35px -15px rgba(0, 0, 0, 0.15);
        }
        .carousel-inner {
            position: relative;
            width: 100%;
            height: 100%;
        }
        .carousel-item {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            transition: opacity 0.8s ease-in-out;
            background-size: cover;
            background-position: center;
        }
        .carousel-item.active {
            opacity: 1;
            z-index: 1;
        }
        .carousel-control {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255,255,255,0.25);
            backdrop-filter: blur(12px);
            color: white;
            border: none;
            width: 48px;
            height: 48px;
            border-radius: 60px;
            font-size: 22px;
            cursor: pointer;
            z-index: 2;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .carousel-control:hover {
            background: #38bdf8;
            transform: translateY(-50%) scale(1.05);
        }
        .prev { left: 28px; }
        .next { right: 28px; }

        .section-block {
            margin-bottom: 64px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            flex-wrap: wrap;
            gap: 16px;
            margin-bottom: 28px;
            border-bottom: 1.5px solid rgba(125, 211, 252, 0.4);
            padding-bottom: 12px;
        }
        .section-title {
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
            letter-spacing: -0.3px;
            background: linear-gradient(135deg, #0c4a6e, #1e6f9f);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }
        .section-title i {
            background: none;
            color: #38bdf8;
            font-size: 1.8rem;
        }
        .section-categories {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        .section-category-chip {
            background: rgba(255,255,255,0.6);
            backdrop-filter: blur(6px);
            padding: 6px 20px;
            border-radius: 60px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.8rem;
            transition: all 0.2s;
            border: 1px solid rgba(125, 211, 252, 0.5);
            color: #0c4a6e;
        }
        .section-category-chip.active, .section-category-chip:hover {
            background: #38bdf8;
            color: white;
            border-color: #38bdf8;
            transform: translateY(-2px);
            box-shadow: 0 8px 14px -6px rgba(56, 189, 248, 0.4);
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 28px;
        }

        .product-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            border-radius: 28px;
            overflow: hidden;
            transition: all 0.35s cubic-bezier(0.15, 0.75, 0.45, 1);
            cursor: pointer;
            box-shadow: 0 12px 24px -12px rgba(0, 0, 0, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.7);
        }
        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 28px 40px -16px rgba(56, 189, 248, 0.3);
            background: white;
            border-color: rgba(56, 189, 248, 0.5);
        }
        
        .product-img {
            aspect-ratio: 1 / 1;
            width: 100%;
            background-size: cover;
            background-position: center;
            transition: transform 0.4s ease;
        }
        .product-card:hover .product-img {
            transform: scale(1.02);
        }

        .product-info {
            padding: 16px 14px 18px;
        }
        .product-title {
            font-weight: 700;
            font-size: 1rem;
            margin-bottom: 6px;
            color: #0a2b3e;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .product-price {
            color: #0ea5e9;
            font-size: 1.3rem;
            font-weight: 800;
        }
        .btn-add-cart {
            background: #38bdf8;
            color: white;
            border: none;
            width: 100%;
            padding: 10px;
            border-radius: 60px;
            margin-top: 12px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 2px 6px rgba(0,0,0,0.05);
        }
        .btn-add-cart:hover {
            background: #0ea5e9;
            transform: scale(1.02);
            box-shadow: 0 8px 18px rgba(56, 189, 248, 0.3);
        }

        @media (max-width: 1024px) {
            .products-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 20px;
            }
        }
        @media (max-width: 640px) {
            .products-grid {
                grid-template-columns: 1fr;
                gap: 16px;
            }
        }

        .cart-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 16px;
        }
        .cart-table th {
            background: rgba(125, 211, 252, 0.12);
            backdrop-filter: blur(8px);
            padding: 16px;
            border-radius: 28px;
            font-weight: 700;
            font-size: 0.9rem;
        }
        .cart-table td {
            background: white;
            padding: 20px 16px;
            border-radius: 28px;
            vertical-align: middle;
            box-shadow: 0 5px 15px rgba(0,0,0,0.02);
        }
        .quantity-input {
            width: 80px;
            padding: 8px 12px;
            border-radius: 40px;
            border: 1px solid #cbd5e1;
            text-align: center;
            font-weight: 500;
        }
        .remove-cart-item {
            background: #fee2e2;
            color: #dc2626;
            border: none;
            padding: 8px 20px;
            border-radius: 40px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }
        .remove-cart-item:hover {
            background: #dc2626;
            color: white;
        }
        .checkout-btn {
            background: linear-gradient(105deg, #0ea5e9, #38bdf8);
            border: none;
            padding: 14px 40px;
            border-radius: 60px;
            color: white;
            font-weight: 700;
            font-size: 1rem;
            box-shadow: 0 10px 20px -5px rgba(14, 165, 233, 0.4);
            cursor: pointer;
            transition: 0.2s;
        }
        .checkout-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 25px -8px rgba(14, 165, 233, 0.5);
        }

        .profile-section {
            background: rgba(255,255,255,0.7);
            backdrop-filter: blur(16px);
            border-radius: 40px;
            padding: 32px;
            margin-bottom: 32px;
            border: 1px solid rgba(255,255,255,0.7);
        }

        .custom-toast {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(20px);
            color: white;
            padding: 14px 32px;
            border-radius: 80px;
            font-weight: 600;
            z-index: 2000;
            display: flex;
            align-items: center;
            gap: 12px;
            animation: toastFloat 2.4s ease forwards;
            pointer-events: none;
            border: 1px solid rgba(255,255,255,0.2);
        }
        @keyframes toastFloat {
            0% { opacity: 0; transform: translate(-50%, -50%) scale(0.94); }
            15% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
            85% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
            100% { opacity: 0; transform: translate(-50%, -50%) scale(0.96); }
        }

        .footer {
            background: #0a2a3a;
            color: #cbd5e6;
            padding: 56px 48px 40px;
            margin-top: 32px;
            border-top: 1px solid rgba(255,255,255,0.1);
        }
        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 48px;
            max-width: 1200px;
            margin: 0 auto;
        }
        .footer-col h3 {
            color: #7dd3fc;
            font-size: 1.2rem;
            margin-bottom: 22px;
            position: relative;
            display: inline-block;
            font-weight: 600;
        }
        .footer-col h3:after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 40px;
            height: 2px;
            background: #38bdf8;
            border-radius: 2px;
        }
        .footer-col p {
            margin: 14px 0;
            line-height: 1.5;
            font-size: 0.9rem;
        }
        .footer-col i {
            width: 28px;
            color: #38bdf8;
        }
        .social-links {
            margin-top: 24px;
            display: flex;
            gap: 18px;
        }
        .social-links a {
            color: #cbd5e6;
            font-size: 1.4rem;
            transition: 0.2s;
        }
        .social-links a:hover {
            color: #7dd3fc;
            transform: translateY(-2px);
        }
        .qr-placeholder {
            width: 100px;
            height: 100px;
            background: rgba(255,255,255,0.1);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            color: #38bdf8;
            margin-bottom: 16px;
        }
        .copyright {
            text-align: center;
            margin-top: 56px;
            padding-top: 24px;
            border-top: 1px solid rgba(255,255,255,0.1);
            font-size: 0.75rem;
            letter-spacing: 0.5px;
        }

        .detail-container {
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(20px);
            border-radius: 48px;
            padding: 36px;
            display: flex;
            gap: 48px;
            flex-wrap: wrap;
            box-shadow: 0 20px 35px -12px rgba(0,0,0,0.1);
        }
        .detail-img {
            flex: 1;
            min-width: 280px;
            border-radius: 32px;
            overflow: hidden;
            box-shadow: 0 15px 25px -8px rgba(0,0,0,0.1);
        }
        .detail-img img {
            width: 100%;
            height: auto;
            display: block;
        }
        .detail-info {
            flex: 1.5;
        }
        .detail-title {
            font-size: 2rem;
            font-weight: 800;
        }
        .detail-price {
            font-size: 2rem;
            color: #0ea5e9;
            font-weight: 800;
            margin: 16px 0;
        }
        .detail-meta {
            background: #eef2ff;
            border-radius: 28px;
            padding: 20px;
            margin: 20px 0;
        }

        .login-card {
            max-width: 520px;
            margin: 40px auto;
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(16px);
            border-radius: 56px;
            padding: 42px 40px;
            box-shadow: 0 25px 40px -15px rgba(0,0,0,0.12);
            border: 1px solid rgba(125, 211, 252, 0.4);
        }
        .login-card h2 {
            text-align: center;
            color: #0c4a6e;
            margin-bottom: 32px;
        }
        .form-group input, .form-group select {
            width: 100%;
            padding: 14px 22px;
            border: 1px solid #cbd5e1;
            border-radius: 60px;
            font-size: 0.95rem;
            transition: all 0.2s;
            background: #fefefe;
        }
        .form-group input:focus {
            outline: none;
            border-color: #38bdf8;
            box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.2);
        }
        .login-btn {
            width: 100%;
            background: linear-gradient(105deg, #0ea5e9, #38bdf8);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 60px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 8px;
        }
        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(14, 165, 233, 0.3);
        }

        @media (max-width: 1024px) {
            .main-content { padding: 28px; }
            .carousel { height: 280px; }
            .footer { padding: 40px 28px; }
        }
        @media (max-width: 768px) {
            .header { padding: 16px 24px; }
            .nav-search-row { flex-direction: column; align-items: stretch; }
            .nav-links { justify-content: center; }
            .section-header { flex-direction: column; align-items: flex-start; gap: 12px; }
        }
    </style>
</head>
<body>
<div class="app">
    <div class="student-badge">
        学号：24215220108  |  姓名：万海璇  |  万璇の谷子店
    </div>
    <div class="header">
        <div class="top-row">
            <div class="logo"><h1>万璇の谷子店</h1></div>
            <div id="authArea" class="user-info"></div>
        </div>
        <div class="nav-search-row">
            <div class="nav-links">
                <button class="nav-btn" data-page="home"><i class="fas fa-home"></i> 首页</button>
                <button class="nav-btn" data-page="cart"><i class="fas fa-shopping-cart"></i> 购物车</button>
                <button class="nav-btn" data-page="profile"><i class="fas fa-user"></i> 个人中心</button>
            </div>
            <div class="search-wrapper">
                <div class="search-box">
                    <input type="text" id="searchInput" placeholder="搜索为你推荐中的商品...">
                    <button id="searchBtn"><i class="fas fa-search"></i> 探索</button>
                </div>
            </div>
        </div>
    </div>

    <div class="main-content">
        <div id="homePage" class="page active-page">
            <div class="carousel">
                <div class="carousel-inner" id="carouselInner"></div>
                <button class="carousel-control prev" id="prevBtn"><i class="fas fa-chevron-left"></i></button>
                <button class="carousel-control next" id="nextBtn"><i class="fas fa-chevron-right"></i></button>
            </div>
            <div class="section-block">
                <div class="section-header">
                    <div class="section-title"><i class="fas fa-star-of-life"></i> 新品首发 · 灵感登场</div>
                    <div class="section-categories" id="newArrivalCats"></div>
                </div>
                <div id="newArrivalGrid" class="products-grid"></div>
            </div>
            <div class="section-block">
                <div class="section-header">
                    <div class="section-title"><i class="fas fa-heart"></i> 为你推荐 · 精选好物</div>
                    <div class="section-categories" id="recommendedCats"></div>
                </div>
                <div id="recommendedGrid" class="products-grid"></div>
            </div>
        </div>
        <div id="detailPage" class="page"><button id="backHomeFromDetail" style="margin-bottom:24px; background:#eef2ff; border:none; padding:10px 24px; border-radius:60px; font-weight:500; cursor:pointer;"><i class="fas fa-arrow-left"></i> 返回首页</button><div id="productDetailContent"></div></div>
        <div id="cartPage" class="page"><h2 style="margin-bottom:28px;"><i class="fas fa-shopping-cart"></i> 购物车</h2><div id="cartList"></div><button id="gotoOrderConfirm" class="checkout-btn">去结算 <i class="fas fa-arrow-right"></i></button></div>
        <div id="orderConfirmPage" class="page"><h2>确认订单</h2><div id="orderConfirmContent"></div><button id="submitOrderBtn" class="checkout-btn">提交订单</button></div>
        <div id="checkoutPage" class="page"><h2>安全支付</h2><div id="checkoutContent"></div><button id="payOrderBtn" class="checkout-btn">确认支付</button></div>
        <div id="profilePage" class="page"><div class="profile-section"><h2>个人中心</h2><div id="profileInfo"></div></div><div class="profile-section"><h3>我的订单</h3><div id="userOrdersList"></div></div><div class="profile-section"><h3>卖家管理</h3><div id="sellerManageArea"></div></div></div>
