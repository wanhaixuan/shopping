<script>
    function showCenteredMessage(msg, type = 'info') {
        const existing = document.querySelector('.custom-toast');
        if(existing) existing.remove();
        const toast = document.createElement('div');
        toast.className = 'custom-toast';
        let icon = type === 'success' ? '✨' : (type === 'error' ? '⚠️' : '💡');
        toast.innerHTML = `${icon} <span>${msg}</span>`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2200);
    }
    window.alert = showCenteredMessage;
    const showSuccess = (msg) => showCenteredMessage(msg, 'success');
    const showError = (msg) => showCenteredMessage(msg, 'error');
    const showInfo = (msg) => showCenteredMessage(msg, 'info');

    const newArrivalProducts = [
        { id: 101, name: '明日方舟-甜忆回响徽章', price: 18, category: '徽章', img: 'images/image0.png', stock: 200, sellerId: 1, desc:'明日方舟×大白兔奶糖联动'},
        { id: 103, name: '帕姆展览馆系列亚克力挂件', price: 28, category: '亚克力', img: 'images/image1.png', stock: 120, sellerId: 1, desc:'老大思考.jpg'},
        { id: 105, name: '群星邀约系列仿生胶片', price: 9.9, category: '纸片', img:'images/image2.png', stock: 500, sellerId: 2, desc:'人之怒pv柄图'},
        { id: 107, name: '刃Q版摇摇乐摆件', price: 99, category: '手办', img: 'images/image3.png', stock: 30, sellerId: 3, desc:'敢坐刃的车吗？'},
        { id: 109, name: 'Q版娃娃系列毛绒玩偶公仔', price: 99, category: '玩偶', img: 'images/image4.png', stock: 80, sellerId: 1, desc:'就这个小敌萌！'},
        { id: 111, name: '角色套组-星语共愿', price: 65, category: '角色套组', img: 'images/image5.png', stock: 120, sellerId: 2, desc:'无息破局皮肤柄图'}
    ];
    const recommendedProducts = [
        { id: 201, name: '明日方舟×三丽鸥家族-趴趴玩偶', price: 38, category: 'logos', img: 'images/image6.png', stock: 15, sellerId: 3, desc:'logos&酷企鹅dubble冷脸萌'},
        { id: 203, name: '金属决策币-中不中', price: 20, category: '左乐', img: 'images/image7.png', stock: 8, sellerId: 1, desc:'河南小伙帮你决定！'},
        { id: 205, name: '果味的夏天系列镭射票', price: 15, category: '万敌', img: 'images/image8.png', stock: 40, sellerId: 2, desc:'小敌的石榴汁分我一点~'},
        { id: 207, name: '崩坏·星穹铁道Q版叠叠乐', price: 39.8, category: '刃', img: 'images/image9.png', stock: 18, sellerId: 3, desc:'我可以坐刃头上吗（'},
        { id: 209, name: '光锥系列亚克力色纸', price: 48, category: '不死途', img: 'images/image10.png', stock: 60, sellerId: 1, desc:'一场谎言的终幕光锥柄图'}
    ];
    const allProductsMap = {};
    [...newArrivalProducts, ...recommendedProducts].forEach(p => { allProductsMap[p.id] = p; });

    let currentUser = JSON.parse(localStorage.getItem('currentUser')) || null;
    let users = JSON.parse(localStorage.getItem('users')) || [];
    let carts = JSON.parse(localStorage.getItem('carts')) || [];
    let orders = JSON.parse(localStorage.getItem('orders')) || [];

    localStorage.setItem('products', JSON.stringify(allProductsMap));
   
    function saveAll(){
        localStorage.setItem('products', JSON.stringify(allProductsMap));
        localStorage.setItem('users', JSON.stringify(users));
        localStorage.setItem('carts', JSON.stringify(carts));
        localStorage.setItem('orders', JSON.stringify(orders));
        if(currentUser) localStorage.setItem('currentUser', JSON.stringify(currentUser));
        else localStorage.removeItem('currentUser');
    }
    function getUserCart(){ return currentUser ? carts.filter(c => c.userId === currentUser.id) : []; }

    let globalSearchKeyword = '';
    let newArrivalCategory = 'all';
    let recommendedCategory = 'all';

    const newArrivalCategoriesList = ['all', '徽章', '亚克力', '纸片', '手办', '玩偶', '角色套组'];
    const recommendedCategoriesList = ['all', '左乐', 'logos', '万敌', '刃', '不死途'];

    function filterByCategory(list, category){
        if(category === 'all') return list;
        return list.filter(p => p.category === category);
    }
    function getNewArrivalFiltered(){ return filterByCategory(newArrivalProducts, newArrivalCategory); }
    function getRecommendedFiltered(){
        let list = recommendedProducts;
        if(globalSearchKeyword) list = list.filter(p => p.name.toLowerCase().includes(globalSearchKeyword.toLowerCase()));
        return filterByCategory(list, recommendedCategory);
    }

    function renderGrid(containerId, productList, withEvents = true){
        const container = document.getElementById(containerId);
        if(!container) return;
        if(productList.length === 0){ container.innerHTML = '<div style="text-align:center; padding:60px;">✨ 暂无商品 ✨</div>'; return; }
        container.innerHTML = productList.map(p => `
            <div class="product-card" data-pid="${p.id}">
                <div class="product-img" style="background-image: url(${p.img});"></div>
                <div class="product-info">
                    <div class="product-title">${p.name}</div>
                    <div class="product-price">¥${p.price}</div>
                    <button class="btn-add-cart" data-pid="${p.id}"><i class="fas fa-cart-plus"></i> 加入购物车</button>
                </div>
            </div>
        `).join('');
        if(!withEvents) return;
        container.querySelectorAll('.product-card').forEach(card => {
            const pid = parseInt(card.dataset.pid);
            card.addEventListener('click', (e) => { if(!e.target.closest('.btn-add-cart')) showProductDetail(pid); });
            const btn = card.querySelector('.btn-add-cart');
            if(btn) btn.addEventListener('click', (e) => { e.stopPropagation(); addToCart(pid); });
        });
    }

    function updateAllBlocks(){
        renderGrid('newArrivalGrid', getNewArrivalFiltered(), true);
        renderGrid('recommendedGrid', getRecommendedFiltered(), true);
    }

    function renderCategoryChips(){
        const newCats = document.getElementById('newArrivalCats');
        if(newCats) newCats.innerHTML = newArrivalCategoriesList.map(cat => `<span class="section-category-chip ${newArrivalCategory === cat ? 'active' : ''}" data-cat="${cat}" data-block="new">${cat === 'all' ? '全部' : cat}</span>`).join('');
        const recCats = document.getElementById('recommendedCats');
        if(recCats) recCats.innerHTML = recommendedCategoriesList.map(cat => `<span class="section-category-chip ${recommendedCategory === cat ? 'active' : ''}" data-cat="${cat}" data-block="rec">${cat === 'all' ? '全部' : cat}</span>`).join('');
        document.querySelectorAll('.section-category-chip').forEach(chip => {
            chip.addEventListener('click', (e) => {
                const cat = chip.dataset.cat, block = chip.dataset.block;
                if(block === 'new') newArrivalCategory = cat;
                else if(block === 'rec') recommendedCategory = cat;
                renderCategoryChips(); updateAllBlocks();
            });
        });
    }

    function addToCart(pid){
        if(!currentUser){ showInfo('请先登录'); showLoginPage(); return; }
        let exist = carts.find(c => c.userId === currentUser.id && c.productId === pid);
        if(exist) exist.quantity += 1;
        else carts.push({ userId: currentUser.id, productId: pid, quantity: 1 });
        saveAll(); showSuccess('已加入购物车');
        if(currentPage === 'cart') renderCartPage();
    }

    function showProductDetail(pid){
        const product = allProductsMap[pid];
        if(!product) return;
        document.getElementById('productDetailContent').innerHTML = `
            <div class="detail-container">
                <div class="detail-img"><img src="${product.img}" alt="${product.name}"></div>
                <div class="detail-info">
                    <div class="detail-title">${product.name}</div>
                    <div class="detail-price">¥${product.price}</div>
                    <div class="detail-meta">
                        <p><i class="fas fa-tag"></i> 分类：${product.category}</p>
                        <p><i class="fas fa-boxes"></i> 库存：${product.stock} 件</p>
                        <p><i class="fas fa-store"></i> 商家：${['万璇优选','同人社团','官方合作'][(product.sellerId-1)]}</p>
                    </div>
                    <p><strong>灵感描述</strong><br>${product.desc}</p>
                    <button id="detailAddCartBtn" class="btn-add-cart" style="width:220px;"><i class="fas fa-cart-plus"></i> 加入购物车</button>
                </div>
            </div>
        `;
        document.getElementById('detailAddCartBtn')?.addEventListener('click', () => addToCart(product.id));
        switchPage('detail');
    }

    function renderCartPage(){
        const items = getUserCart();
        if(!items.length){ document.getElementById('cartList').innerHTML = '<div style="padding:60px;text-align:center;">🛒 购物车还是空的</div>'; return; }
        let total=0, html=`<table class="cart-table"><thead><tr><th>商品</th><th>单价</th><th>数量</th><th>小计</th><th>操作</th></td></thead><tbody>`;
        items.forEach(item=>{
            const prod = allProductsMap[item.productId];
            if(!prod) return;
            const sub = prod.price * item.quantity;
            total += sub;
            html += `<tr>
                <td><strong>${prod.name}</strong></td>
                <td>¥${prod.price}</td>
                <td><input type="number" min="1" value="${item.quantity}" class="quantity-input" data-id="${item.productId}"></td>
                <td>¥${sub}</td>
                <td><button class="remove-cart-item" data-id="${item.productId}">删除</button></td>
            </tr>`;
        });
        html += `</tbody><tfoot><tr><td colspan="3"><strong>总计</strong></td><td colspan="2"><strong style="color:#0ea5e9;">¥${total}</strong></td></tr></tfoot></table>`;
        document.getElementById('cartList').innerHTML = html;
        document.querySelectorAll('.quantity-input').forEach(inp => inp.addEventListener('change', () => {
            let pid = parseInt(inp.dataset.id), q = parseInt(inp.value);
            if(q > 0){ let ci = carts.find(c=>c.userId===currentUser.id && c.productId===pid); if(ci) ci.quantity = q; saveAll(); renderCartPage(); }
        }));
        document.querySelectorAll('.remove-cart-item').forEach(btn => btn.addEventListener('click', () => {
            let pid = parseInt(btn.dataset.id);
            carts = carts.filter(c => !(c.userId === currentUser.id && c.productId === pid));
            saveAll(); renderCartPage(); showInfo('已移除');
        }));
    }

    function renderOrderConfirm(){
        const items = getUserCart();
        if(!items.length){ document.getElementById('orderConfirmContent').innerHTML='<p>购物车为空</p>'; return; }
        let total=0,html='<ul style="list-style:none;">';
        items.forEach(item=>{ const p = allProductsMap[item.productId]; if(p){ total += p.price * item.quantity; html += `<li>📦 ${p.name} x ${item.quantity}  ¥${p.price*item.quantity}</li>`; } });
        html += `</ul><div style="background:#eef2ff; border-radius:28px; padding:20px; margin-top:20px;"><h3>订单总额 ¥${total}</h3><p>收货地址：广东省佛山市南海区信息大道</p></div>`;
        document.getElementById('orderConfirmContent').innerHTML = html;
        window.pendingOrderTotal = total;
    }
    function submitOrder(){
        const items = getUserCart(); if(!items.length) return showError('购物车为空');
        const newOrder = { id: Date.now(), userId: currentUser.id, items: items.map(i => ({ productId: i.productId, quantity: i.quantity })), total: window.pendingOrderTotal, status: '待付款', createTime: new Date().toLocaleString() };
        orders.push(newOrder); carts = carts.filter(c => c.userId !== currentUser.id);
        saveAll(); showSuccess('订单已生成'); switchPage('checkout'); renderCheckoutPage(newOrder.id);
    }
    function renderCheckoutPage(orderId){
        const order = orders.find(o => o.id === orderId);
        if(order){
            document.getElementById('checkoutContent').innerHTML = `<div style="background:white; border-radius:32px; padding:28px;"><h3>订单号: ${order.id}</h3><p>支付金额: <strong style="color:#0ea5e9;">¥${order.total}</strong></p><button id="mockPayBtn" class="checkout-btn">立即支付</button></div>`;
            document.getElementById('mockPayBtn')?.addEventListener('click', () => { order.status = '已支付'; saveAll(); showSuccess('支付成功'); switchPage('profile'); renderProfilePage(); });
        }
    }
    function renderProfilePage(){
        if(!currentUser) return showLoginPage();
        document.getElementById('profileInfo').innerHTML = `<p><i class="fas fa-user-circle"></i> ${currentUser.username} · ${currentUser.role === 'buyer' ? '买家' : (currentUser.role === 'seller' ? '卖家' : '管理员')} <button id="logoutBtnProfile" class="logout-btn" style="margin-left:16px;">退出登录</button></p>`;
        document.getElementById('logoutBtnProfile')?.addEventListener('click', logout);
        const userOrders = orders.filter(o => o.userId === currentUser.id);
        document.getElementById('userOrdersList').innerHTML = userOrders.length ? userOrders.map(o => `<div style="border-radius:24px; background:#f8fafc; margin:14px 0; padding:16px;"><strong>订单#${o.id}</strong> ¥${o.total} · ${o.status}<br><small>${o.createTime}</small></div>`).join('') : '<p>暂无订单</p>';
        if(currentUser.role === 'seller' || currentUser.role === 'admin'){
            document.getElementById('sellerManageArea').innerHTML = `<div id="sellerProductsList" class="products-grid"></div>`;
            const allProds = Object.values(allProductsMap);
            const sContainer = document.getElementById('sellerProductsList');
            if(sContainer){
                sContainer.innerHTML = allProds.map(p => `<div class="product-card" style="cursor:default;">
                    <div class="product-img" style="aspect-ratio: 1 / 1; width: 100%; background-size: cover; background-position: center; background-image: url(${p.img});"></div>
                    <div style="padding:12px;">
                        <b>${p.name}</b> <span class="product-price">¥${p.price}</span><br>
                        <button data-id="${p.id}" class="edit-product-btn" style="background:#38bdf8; border-radius:40px; padding:6px 18px; margin-top:10px; margin-right:10px;">编辑</button>
                        <button data-id="${p.id}" class="del-product-btn" style="background:#ef4444; border-radius:40px; padding:6px 18px;">删除</button>
                    </div>
                </div>`).join('');
                document.querySelectorAll('.del-product-btn').forEach(btn => btn.addEventListener('click', () => {
                    let pid = parseInt(btn.dataset.id); delete allProductsMap[pid];
                    const newIdx = newArrivalProducts.findIndex(p => p.id === pid); if(newIdx !== -1) newArrivalProducts.splice(newIdx,1);
                    const recIdx = recommendedProducts.findIndex(p => p.id === pid); if(recIdx !== -1) recommendedProducts.splice(recIdx,1);
                    saveAll(); renderProfilePage(); updateAllBlocks(); showSuccess('已删除');
                }));
                document.querySelectorAll('.edit-product-btn').forEach(btn => btn.addEventListener('click', () => {
                    let pid = parseInt(btn.dataset.id), prod = allProductsMap[pid];
                    let newName = prompt('新名称', prod.name); if(newName?.trim()) prod.name = newName.trim();
                    let newPrice = parseFloat(prompt('新价格', prod.price)); if(!isNaN(newPrice) && newPrice > 0) prod.price = newPrice;
                    saveAll(); renderProfilePage(); updateAllBlocks(); showSuccess('更新成功');
                }));
            }
        } else document.getElementById('sellerManageArea').innerHTML = '<p>✨ 买家模式，切换卖家账号体验商品管理</p>';
    }

    let currentPage = 'home';
    function switchPage(page){
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active-page'));
        document.getElementById(`${page}Page`).classList.add('active-page');
        currentPage = page;
        if(page === 'home'){ if(autoInterval) clearInterval(autoInterval); startCarousel(); renderCategoryChips(); updateAllBlocks(); }
        if(page === 'cart') renderCartPage();
        if(page === 'orderConfirm') renderOrderConfirm();
        if(page === 'profile') renderProfilePage();
        document.querySelectorAll('.nav-btn').forEach(btn => { if(btn.dataset.page === page) btn.classList.add('active'); else btn.classList.remove('active'); });
    }
    function showLoginPage(){ switchPage('login'); }
    function logout(){ currentUser = null; saveAll(); showInfo('已退出'); location.reload(); }
    function initAuth(){
        const div = document.getElementById('authArea');
        if(currentUser) div.innerHTML = `<span class="user-name"><i class="fas fa-user-astronaut"></i> ${currentUser.username}</span><button class="logout-btn" id="logoutNavBtn">登出</button>`;
        else div.innerHTML = `<button id="loginNavBtn" style="background:#38bdf8; color:white; border-radius:60px; padding:6px 22px; border:none; font-weight:600;">登录 / 注册</button>`;
        document.getElementById('logoutNavBtn')?.addEventListener('click', logout);
        document.getElementById('loginNavBtn')?.addEventListener('click', showLoginPage);
    }
    function bindLogin(){
        document.getElementById('doLoginBtn')?.addEventListener('click', () => {
            let uname = document.getElementById('loginUsername').value, pwd = document.getElementById('loginPassword').value;
            let user = users.find(u => u.username === uname && u.password === pwd);
            if(user){ currentUser = { id: user.id, username: user.username, role: user.role, name: user.name }; saveAll(); showSuccess('登录成功'); location.reload(); }
            else showError('账号或密码错误');
        });
        document.getElementById('showRegisterBtn')?.addEventListener('click', () => { document.getElementById('loginForm').style.display = 'none'; document.getElementById('registerForm').style.display = 'block'; });
        document.getElementById('showLoginBtn')?.addEventListener('click', () => { document.getElementById('loginForm').style.display = 'block'; document.getElementById('registerForm').style.display = 'none'; });
        document.getElementById('doRegisterBtn')?.addEventListener('click', () => {
            let uname = document.getElementById('regUsername').value, pwd = document.getElementById('regPassword').value, role = document.getElementById('regRole').value;
            if(users.find(u => u.username === uname)){ showError('用户名已存在'); return; }
            users.push({ id: users.length + 100, username: uname, password: pwd, role, name: uname });
            saveAll(); showSuccess('注册成功，请登录');
            document.getElementById('loginForm').style.display = 'block'; document.getElementById('registerForm').style.display = 'none';
        });
    }

    // ========== 淡入淡出轮播图实现 ==========
    const carouselImages = ['images/image11.png', 'images/image12.png', 'images/image13.png','images/image14.png','images/image15.png'];
    let slideIndex = 0;
    let autoInterval;

    function renderCarousel() {
        const inner = document.getElementById('carouselInner');
        if (!inner) return;
        inner.innerHTML = carouselImages.map((url, idx) => `
            <div class="carousel-item" style="background-image: linear-gradient(to top, rgba(0,0,0,0.2), rgba(0,0,0,0.05)), url(${url});" data-index="${idx}"></div>
        `).join('');
        // 激活第一张
        const firstItem = inner.querySelector('.carousel-item');
        if (firstItem) firstItem.classList.add('active');
    }

    function showSlide(index) {
        const items = document.querySelectorAll('.carousel-item');
        if (!items.length) return;
        // 循环取模，实现无缝
        let validIndex = (index + carouselImages.length) % carouselImages.length;
        items.forEach(item => item.classList.remove('active'));
        items[validIndex].classList.add('active');
        slideIndex = validIndex;
    }

    function nextSlide() {
        showSlide(slideIndex + 1);
    }

    function prevSlide() {
        showSlide(slideIndex - 1);
    }

    function startCarousel() {
        autoInterval = setInterval(() => {
            nextSlide();
        }, 4800);
    }

    // 绑定轮播图按钮（覆盖原有绑定）
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    if (prevBtn) {
        prevBtn.addEventListener('click', () => {
            if (autoInterval) clearInterval(autoInterval);
            prevSlide();
            startCarousel();
        });
    }
    if (nextBtn) {
        nextBtn.addEventListener('click', () => {
            if (autoInterval) clearInterval(autoInterval);
            nextSlide();
            startCarousel();
        });
    }

    // ========== 页面启动 ==========
    document.querySelectorAll('.nav-btn').forEach(btn => btn.addEventListener('click', () => { let target = btn.dataset.page; if((target === 'cart' || target === 'profile') && !currentUser){ showInfo('请先登录'); showLoginPage(); return; } switchPage(target); }));
    document.getElementById('searchBtn')?.addEventListener('click', () => { globalSearchKeyword = document.getElementById('searchInput').value.trim(); updateAllBlocks(); });
    document.getElementById('gotoOrderConfirm')?.addEventListener('click', () => { if(currentUser && getUserCart().length) switchPage('orderConfirm'); else showInfo('请登录或购物车为空'); });
    document.getElementById('submitOrderBtn')?.addEventListener('click', submitOrder);
    document.getElementById('backHomeFromDetail')?.addEventListener('click', () => switchPage('home'));

    renderCarousel(); startCarousel(); renderCategoryChips(); updateAllBlocks(); initAuth(); bindLogin();
    if(!currentUser) switchPage('home'); else switchPage('home');
</script>
</body>
</html>
